<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BGMI</title>

<style>

body{
    margin:0;
    font-family: Arial, Helvetica, sans-serif;
    background:#111;
    color:white;
}

header{
    background:black;
    padding:15px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

nav a{
    color:white;
    margin:0 10px;
    text-decoration:none;
    font-weight:bold;
}

nav a:hover{
    color:orange;
}

.hero{
    height:90vh;
    background:url("https://wallpaperaccess.com/full/6456352.jpg") center/cover no-repeat;
    display:flex;
    align-items:center;
    justify-content:center;
    text-align:center;
}

.hero h2{
    font-size:50px;
}

.btn{
    display:inline-block;
    margin-top:15px;
    padding:10px 25px;
    background:orange;
    color:black;
    font-weight:bold;
    text-decoration:none;
    border-radius:5px;
}

.features{
    padding:50px;
    text-align:center;
}

.cards{
    display:flex;
    justify-content:center;
    gap:20px;
}

.card{
    background:#222;
    padding:20px;
    width:200px;
    border-radius:10px;
}

.card:hover{
    transform:scale(1.05);
}

.weapons{
    padding:50px;
    text-align:center;
}

.weapon-list{
    display:flex;
    justify-content:center;
    gap:20px;
}

.weapon{
    background:#222;
    padding:20px;
    width:200px;
    border-radius:10px;
